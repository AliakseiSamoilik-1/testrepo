aws dynamodb create-table ^    --table-name tank-ws-server-connections ^    --billing-mode PAY_PER_REQUEST ^    --region eu-central-1 ^    --attribute-definitions ^        AttributeName=connectionId,AttributeType=S ^        AttributeName=room,AttributeType=S ^        AttributeName=role,AttributeType=S ^    --key-schema AttributeName=connectionId,KeyType=HASH ^    --global-secondary-indexes "[{\"IndexName\":\"RoomRoleIndex\",\"KeySchema\":[{\"AttributeName\":\"room\",\"KeyType\":\"HASH\"},{\"AttributeName\":\"role\",\"KeyType\":\"RANGE\"}],\"Projection\":{\"ProjectionType\":\"KEYS_ONLY\"}}]"